# =============================================================================
# Environment Configuration for Dasibom
# =============================================================================

# Database Configuration (Production)
DB_NAME=dasibom
DB_USERNAME=dasibom_user
DB_PASSWORD=your_secure_password_here
DB_PORT=5432

# Backend Configuration
APP_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# Redis Configuration
REDIS_PORT=6379

# Development Database Configuration (for dev environment)
# DB_NAME=dasibom_dev
# DB_USERNAME=dev_user
# DB_PASSWORD=dev_password
# DB_PORT=5433
# APP_PORT=8081
# REDIS_PORT=6380

# pgAdmin Configuration (Development only)
PGADMIN_EMAIL=admin@dasibom.com
PGADMIN_PASSWORD=admin123

# =============================================================================
# AWS/EC2 Specific Configuration
# =============================================================================

# Application URL (update with your domain)
APP_URL=http://localhost:8080

# AWS Region
AWS_REGION=ap-northeast-2

# S3 Configuration (if using S3 for file storage)
# AWS_S3_BUCKET_NAME=dasibom-files
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# RDS Configuration (if using AWS RDS instead of containerized DB)
# RDS_ENDPOINT=your-rds-endpoint.amazonaws.com
# RDS_PORT=5432

# ElastiCache Configuration (if using AWS ElastiCache instead of containerized Redis)
# ELASTICACHE_ENDPOINT=your-elasticache-endpoint.amazonaws.com
# ELASTICACHE_PORT=6379

# =============================================================================
# Security Configuration
# =============================================================================

# JWT Secret (change this in production!)
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# CORS Origins (update with your frontend domains)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# =============================================================================
# SSL/TLS Configuration (for production)
# =============================================================================

# SSL Certificate paths (if using custom certificates)
# SSL_CERT_PATH=/etc/ssl/certs/dasibom.crt
# SSL_KEY_PATH=/etc/ssl/private/dasibom.key

# Let's Encrypt Configuration (if using certbot)
# LETSENCRYPT_EMAIL=admin@yourdomain.com
# LETSENCRYPT_DOMAIN=yourdomain.com

# =============================================================================
# Monitoring & Logging
# =============================================================================

# Log Level
LOG_LEVEL=INFO

# External monitoring (if using services like DataDog, New Relic, etc.)
# MONITORING_API_KEY=your_monitoring_api_key

# =============================================================================
# Development Tools (only for development environment)
# =============================================================================

# MailHog (email testing)
MAILHOG_SMTP_PORT=1025
MAILHOG_WEB_PORT=8025

# Debug Configuration
DEBUG_PORT=5005

# =============================================================================
# Notes
# =============================================================================
# 
# For Production (EC2):
# - Change all default passwords
# - Set strong JWT_SECRET
# - Configure proper CORS_ORIGINS
# - Set up SSL certificates
# - Configure AWS services if needed
# 
# For Development:
# - Use docker-compose.dev.yml
# - Uncomment development-specific variables above
# - Access pgAdmin at http://localhost:5050
# - Access MailHog at http://localhost:8025
#
# Commands:
# - Production: docker compose up -d
# - Development: docker compose -f docker-compose.dev.yml up -d
# =============================================================================